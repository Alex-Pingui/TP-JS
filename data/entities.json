{
  "entites":[
    { "id": 1, "nom": "Chauve-souris", "comportement": "passif", "categories": ["animal"], "description": "Petite créature volante vivant dans les grottes. Elle ne peut pas être apprivoisée et ne laisse aucun objet lorsqu'elle meurt.", "pv": 6, "hauteur": 0.9, "largeur": 0.5, "image": "bat.png" },

    { "id": 2, "nom": "Blaze", "comportement": "hostile", "categories": ["monstre"], "description": "Créature du Nether capable de flotter et de lancer des boules de feu. Elle apparaît principalement dans les forteresses du Nether.", "pv": 20, "hauteur": 1.8, "largeur": 0.6, "image": "blaze.png" },

    { "id": 3, "nom": "Poulet", "comportement": "passif", "categories": ["animal"], "description": "Petit animal de ferme qui pond des œufs régulièrement. Il peut aussi servir de source de nourriture.", "pv": 4, "hauteur": 0.7, "largeur": 0.4, "image": "chicken.png" },

    { "id": 4, "nom": "Morue", "comportement": "passif", "categories": ["animal","aquatique"], "description": "Poisson que l'on trouve dans les océans et les rivières. Il peut être pêché ou tué pour obtenir de la nourriture.", "pv": 3, "hauteur": 0.3, "largeur": 0.5, "image": "cod.png" },

    { "id": 5, "nom": "Vache", "comportement": "passif", "categories": ["animal"], "description": "Animal d'élevage qui fournit du cuir et du bœuf. On peut aussi utiliser un seau pour obtenir du lait.", "pv": 10, "hauteur": 1.4, "largeur": 0.9, "image": "cow.png" },

    { "id": 6, "nom": "Creeper", "comportement": "hostile", "categories": ["monstre"], "description": "Monstre emblématique qui explose lorsqu'il s'approche d'un joueur. Il apparaît principalement la nuit ou dans l'obscurité.", "pv": 20, "hauteur": 1.7, "largeur": 0.6, "image": "creeper.png" },

    { "id": 7, "nom": "Dauphin", "comportement": "neutre", "categories": ["animal","aquatique"], "description": "Créature marine amicale qui peut guider les joueurs vers des trésors sous-marins.", "pv": 10, "hauteur": 0.6, "largeur": 0.9, "image": "dolphin.png" },

    { "id": 8, "nom": "Ane", "comportement": "passif", "categories": ["animal"], "description": "Animal montable pouvant transporter un coffre. Il est utile pour transporter des objets sur de longues distances.", "pv": 30, "hauteur": 1.5, "largeur": 1.4, "image": "donkey.png" },

    { "id": 9, "nom": "Noyé", "comportement": "hostile", "categories": ["monstre","mort-vivant"], "description": "Variante aquatique du zombie qui apparaît dans l'eau. Il peut parfois porter un trident.", "pv": 20, "hauteur": 1.95, "largeur": 0.6, "image": "drowned.png" },

    { "id": 10, "nom": "Ancien gardien", "comportement": "hostile", "categories": ["monstre","aquatique"], "description": "Créature puissante gardant les monuments océaniques. Elle inflige l'effet de fatigue minière aux joueurs proches.", "pv": 80, "hauteur": 1.99, "largeur": 1.99, "image": "elder_guardian.png" },

    { "id": 11, "nom": "Dragon de l'End", "comportement": "hostile", "categories": ["monstre","boss"], "description": "Boss principal de l'End. Sa défaite marque la fin du jeu et permet d'accéder à d'autres îles de l'End.", "pv": 200, "hauteur": 8, "largeur": 16, "image": "ender_dragon.png" },

    { "id": 12, "nom": "Enderman", "comportement": "neutre", "categories": ["monstre"], "description": "Créature mystérieuse capable de se téléporter et de déplacer certains blocs. Elle devient hostile si on la regarde dans les yeux.", "pv": 40, "hauteur": 2.9, "largeur": 0.6, "image": "enderman.png" },

    { "id": 13, "nom": "Evocateur", "comportement": "hostile", "categories": ["illageois","monstre"], "description": "Illageois puissant capable d'invoquer des créatures appelées Vex et d'attaquer avec de la magie.", "pv": 24, "hauteur": 1.95, "largeur": 0.6, "image": "evoker.png" },

    { "id": 14, "nom": "Ghast", "comportement": "hostile", "categories": ["monstre"], "description": "Grande créature flottante du Nether qui attaque en lançant des boules de feu explosives.", "pv": 10, "hauteur": 4, "largeur": 4, "image": "ghast.png" },

    { "id": 15, "nom": "Cheval", "comportement": "passif", "categories": ["animal"], "description": "Animal montable rapide qui peut être apprivoisé et équipé d'une selle et d'une armure.", "pv": 30, "hauteur": 1.6, "largeur": 1.4, "image": "horse.png" },

    { "id": 16, "nom": "Golem de fer", "comportement": "neutre", "categories": ["golem"], "description": "Créature protectrice des villages. Elle attaque les monstres et défend les villageois.", "pv": 100, "hauteur": 2.7, "largeur": 1.4, "image": "iron_golem.png" },

    { "id": 17, "nom": "Mooshroom", "comportement": "passif", "categories": ["animal"], "description": "Variante spéciale de vache vivant dans les biomes champignons. Elle peut fournir de la soupe de champignons.", "pv": 10, "hauteur": 1.4, "largeur": 0.9, "image": "mooshroom.png" },

    { "id": 18, "nom": "Ocelot", "comportement": "passif", "categories": ["animal"], "description": "Félin sauvage vivant dans la jungle. Il est très rapide et craint les joueurs.", "pv": 10, "hauteur": 0.7, "largeur": 0.6, "image": "ocelot.png" },

    { "id": 19, "nom": "Perroquet", "comportement": "passif", "categories": ["animal"], "description": "Oiseau coloré pouvant se poser sur l'épaule du joueur et imiter les sons des monstres proches.", "pv": 6, "hauteur": 0.9, "largeur": 0.5, "image": "parrot.png" },

    { "id": 20, "nom": "Cochon", "comportement": "passif", "categories": ["animal"], "description": "Animal d'élevage courant qui peut être monté avec une selle et dirigé à l'aide d'une carotte sur un bâton.", "pv": 10, "hauteur": 0.9, "largeur": 0.9, "image": "pig.png" },

    { "id": 21, "nom": "Ours polaire", "comportement": "neutre", "categories": ["animal"], "description": "Ours vivant dans les biomes glacés. Il devient agressif si un joueur s'approche de ses petits.", "pv": 30, "hauteur": 1.4, "largeur": 1.3, "image": "polar_bear.png" },

    { "id": 22, "nom": "Poisson-globe", "comportement": "neutre", "categories": ["animal","aquatique"], "description": "Poisson capable de se gonfler lorsqu'il est menacé et d'empoisonner les joueurs qui s'en approchent.", "pv": 3, "hauteur": 0.7, "largeur": 0.7, "image": "pufferfish.png" },

    { "id": 23, "nom": "Saumon", "comportement": "passif", "categories": ["animal","aquatique"], "description": "Poisson vivant dans les rivières et océans froids. Il peut être pêché pour obtenir de la nourriture.", "pv": 3, "hauteur": 0.4, "largeur": 0.7, "image": "salmon.png" },

    { "id": 24, "nom": "Mouton", "comportement": "passif", "categories": ["animal"], "description": "Animal fournissant de la laine qui peut être teinte et utilisée pour fabriquer des lits ou des blocs décoratifs.", "pv": 8, "hauteur": 1.3, "largeur": 0.9, "image": "sheep.png" },

    { "id": 25, "nom": "Shulker", "comportement": "hostile", "categories": ["monstre"], "description": "Créature de l'End qui se cache dans une coquille et tire des projectiles provoquant l'effet de lévitation.", "pv": 30, "hauteur": 1, "largeur": 1, "image": "shulker.png" },

    { "id": 26, "nom": "Silverfish", "comportement": "hostile", "categories": ["monstre","arthropode"], "description": "Petit monstre rapide vivant dans certains blocs de pierre. Il apparaît souvent dans les forteresses.", "pv": 8, "hauteur": 0.3, "largeur": 0.4, "image": "silverfish.png" },

    { "id": 27, "nom": "Squelette", "comportement": "hostile", "categories": ["monstre","mort-vivant"], "description": "Monstre mort-vivant armé d'un arc qui attaque les joueurs à distance.", "pv": 20, "hauteur": 1.99, "largeur": 0.6, "image": "skeleton.png" },

    { "id": 28, "nom": "Cheval squelette", "comportement": "passif", "categories": ["animal","mort-vivant"], "description": "Variante rare de cheval mort-vivant apparaissant lors d'événements spéciaux pendant les orages.", "pv": 15, "hauteur": 1.6, "largeur": 1.4, "image": "skeleton_horse.png" },

    { "id": 29, "nom": "Slime", "comportement": "hostile", "categories": ["monstre"], "description": "Créature gélatineuse qui se divise en plusieurs slimes plus petits lorsqu'elle est vaincue.", "pv": 16, "hauteur": 2.04, "largeur": 2.04, "image": "slime.png" },

    { "id": 30, "nom": "Araignée", "comportement": "neutre", "categories": ["monstre","arthropode"], "description": "Araignée géante capable de grimper aux murs. Elle devient hostile la nuit.", "pv": 16, "hauteur": 0.9, "largeur": 1.4, "image": "spider.png" },

    { "id": 31, "nom": "Poulpe", "comportement": "passif", "categories": ["animal","aquatique"], "description": "Créature marine qui nage dans les océans et laisse tomber de l'encre lorsqu'elle est vaincue.", "pv": 10, "hauteur": 0.8, "largeur": 0.8, "image": "squid.png" },

    { "id": 32, "nom": "Tortue", "comportement": "passif", "categories": ["animal","aquatique"], "description": "Tortue vivant sur les plages. Elle pond des œufs qui peuvent éclore en bébés tortues.", "pv": 30, "hauteur": 0.4, "largeur": 1.2, "image": "turtle.png" },

    { "id": 33, "nom": "Villageois", "comportement": "passif", "categories": [], "description": "Habitant des villages avec différents métiers. Ils permettent de faire du commerce avec les joueurs.", "pv": 20, "hauteur": 1.95, "largeur": 0.6, "image": "villager.png" },

    { "id": 34, "nom": "Vindicateur", "comportement": "hostile", "categories": ["illageois","monstre"], "description": "Illageois agressif armé d'une hache qui attaque les joueurs et les villageois.", "pv": 24, "hauteur": 1.95, "largeur": 0.6, "image": "vindicator.png" },

    { "id": 35, "nom": "Sorcière", "comportement": "hostile", "categories": ["monstre"], "description": "Ennemie utilisant des potions pour attaquer ou se soigner pendant le combat.", "pv": 26, "hauteur": 1.95, "largeur": 0.6, "image": "witch.png" },

    { "id": 36, "nom": "Wither", "comportement": "hostile", "categories": ["monstre","mort-vivant","boss"], "description": "Boss puissant invoqué par le joueur. Il tire des projectiles explosifs et régénère sa vie.", "pv": 300, "hauteur": 3.5, "largeur": 0.9, "image": "wither.png" },

