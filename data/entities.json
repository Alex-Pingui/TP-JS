    { "id": 38, "nom": "Loup", "comportement": "neutre", "categories": ["animal"], "description": "Animal pouvant être apprivoisé pour devenir un compagnon fidèle qui attaque les ennemis.", "pv": 8, "hauteur": 0.85, "largeur": 0.6, "image": "wolf.png" },

